# Environment variables template
# Copy this to .env and fill with your actual values

# Hugging Face token (required only if ENABLE_DIARIZATION=true)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=

# API Key for authentication (optional - leave empty to disable auth)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Gemini API Key for summarization (optional)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# AWS S3 credentials (optional - for S3 URL support)
# Leave empty to disable S3 URL support (HTTP/HTTPS URLs will still work)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Model configuration
MODEL_SIZE=small
ENABLE_DIARIZATION=false
CPU_THREADS=4

# Server configuration
HOST=0.0.0.0
PORT=8000

# Protection limits (prevents server overload)
# Maximum concurrent transcription requests (recommended: 2-5)
MAX_CONCURRENT_REQUESTS=3

# Request timeout in seconds (default: 300 = 5 minutes)
REQUEST_TIMEOUT=300

# Rate limit per IP address (format: "requests/period")
# Examples: "10/minute", "100/hour", "5/second"
RATE_LIMIT=10/minute

# Global rate limit for ALL IPs combined (prevents total overload)
# Set this to prevent attacks from multiple IPs
GLOBAL_RATE_LIMIT=50/minute

# Maximum file size in MB
MAX_FILE_SIZE_MB=100

# Job expiry time in seconds (cleanup old jobs)
JOB_EXPIRY_SECONDS=3600
